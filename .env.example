NODE_ENV=development
PORT=3000
SESSION_SECRET=change_this_secret_in_production

# Local (XAMPP): base califloral, usuario root, sin contrasena.
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=califloral
# DB_USER=root
# DB_PASSWORD=

# Solo local si quieres SQLite (NO funciona en Vercel):
# DB_DIALECT=sqlite

# --- Vercel + MySQL en la nube (Railway, Aiven, PlanetScale, etc.) ---
# NODE_ENV=production
# SESSION_SECRET=una_clave_larga_y_aleatoria
# DB_HOST=tu-host.mysql.provider.com
# DB_PORT=3306
# DB_NAME=califloral
# DB_USER=tu_usuario
# DB_PASSWORD=tu_password
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# SKIP_DB_CREATE=true

# Pasarela de pagos (opcional)
# PAYMENT_PROVIDER=mock
# PAYMENT_PROVIDER_API_KEY=
# PAYMENT_PROVIDER_PUBLIC_KEY=
