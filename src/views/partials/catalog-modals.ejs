<div id="product-modal" class="product-modal" aria-hidden="true">
  <div class="product-modal-card" role="dialog" aria-modal="true" aria-label="Detalle de producto">
    <button id="close-product-modal-btn" type="button" class="modal-close-btn">x</button>
    <div class="modal-media">
      <img id="modal-product-image" class="modal-image" alt="" />
      <div class="modal-emoji" id="modal-product-emoji"></div>
    </div>
    <h3 id="modal-product-name"></h3>
    <p id="modal-product-description"></p>
    <strong id="modal-product-price" class="modal-price"></strong>
    <form action="/cart/add" method="POST" class="stack-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="productId" id="modal-product-id" />
      <label>
        Cantidad
        <input type="number" name="quantity" min="1" value="1" />
      </label>
      <button class="primary-btn" type="submit">Agregar al carrito</button>
      <a
        id="modal-wa-btn"
        class="product-wa-btn modal-wa-btn"
        href="#"
        data-product-name=""
        data-product-price=""
        data-product-image=""
        target="_blank"
        rel="noopener noreferrer"
      >
        <i class="fa-brands fa-whatsapp"></i> Consultar por WhatsApp
      </a>
    </form>
  </div>
</div>

<script src="/js/store.js"></script>
<a
  class="whatsapp-float"
  href="https://wa.me/573222530652"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Contactar por WhatsApp"
>
  <i class="fa-brands fa-whatsapp"></i>
</a>
