<%- include("../partials/head", { title }) %>
<%- include("../partials/nav") %>
<main class="page-stack floral-home">
  <section class="hero-banner floral-hero shell">
    <div class="hero-copy-col">
      <h1>Expresa lo que<br />sientes <span>con flores</span></h1>
      <p>Disenos unicos, flores frescas y entregas rapidas para cada ocasion especial.</p>
      <a class="hero-cta" href="/auth/login"><i class="fa-solid fa-cart-shopping"></i> COMPRAR AHORA</a>
    </div>
    <div class="hero-image-col">
      <img src="/img/rosasprincipal.jpg" alt="Rosas principales" />
    </div>
  </section>

  <section class="shell showcase-panel">
    <% if (error) { %>
    <p class="alert error"><%= error %></p>
    <% } %>
    <% if (message) { %>
    <p class="alert success"><%= message %></p>
    <% } %>

    <div class="showcase-layout">
      <%- include("../partials/catalog-sidebar") %>

      <section class="featured-panel">
        <div class="featured-header">
          <h2>Productos destacados</h2>
          <a href="/categoria/ramos">Ver ramos</a>
        </div>
        <%- include("../partials/catalog-product-grid", { products: featuredProducts }) %>
      </section>
    </div>
  </section>

  <section class="shell trust-strip">
    <article><strong><i class="fa-solid fa-truck-fast"></i> Envios rapidos</strong><span>El mismo dia en Cali</span></article>
    <article><strong><i class="fa-solid fa-leaf"></i> Flores frescas</strong><span>Calidad garantizada</span></article>
    <article><strong><i class="fa-regular fa-heart"></i> Disenos unicos</strong><span>Hechos con amor</span></article>
    <article><strong><i class="fa-solid fa-lock"></i> Pago seguro</strong><span>Tus compras protegidas</span></article>
  </section>

  <%- include("../partials/cart-panel") %>
</main>

<%- include("../partials/catalog-modals") %>
<%- include("../partials/footer") %>
